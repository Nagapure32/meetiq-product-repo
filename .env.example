# MeetIQ platform environment example
# Copy to .env and fill local values.

# Runtime
APP_ENV=development
APP_NAME=MeetIQ
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# FastAPI security
BACKEND_SECRET_KEY=replace-with-random-secret
BOT_INTERNAL_API_KEY=replace-with-random-service-key
DEV_USER_ID=replace-with-local-supabase-auth-user-id
AUTH_REQUIRED=false
ALLOW_DEV_USER_FALLBACK=true
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
DATABASE_URL=postgresql+psycopg://postgres:password@db.your-project.supabase.co:5432/postgres

# Next.js public environment
NEXT_PUBLIC_APP_NAME=MeetIQ
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Microsoft identity / Graph
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/microsoft/callback

# Deployed .NET Teams bot integration
TEAMS_BOT_BASE_URL=https://your-teams-bot.example.com
TEAMS_BOT_CALLBACK_URL=https://your-teams-bot.example.com/api/calls
TEAMS_BOT_MESSAGES_URL=https://your-teams-bot.example.com/api/messages
TEAMS_BOT_APP_ID=your-teams-bot-app-id

# Azure Speech
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_API_VERSION=2025-10-15
AZURE_SPEECH_DEFAULT_LANGUAGE=en-IN
AZURE_SPEECH_AUTO_DETECT_LANGUAGES=en-IN,en-US,hi-IN,mr-IN

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_TRANSCRIPT_CONTAINER=meeting-transcripts
AZURE_TRANSCRIPT_PREFIX=transcripts
AZURE_MEDIA_CONTAINER=meeting-transcripts
AZURE_MEDIA_PREFIX=uploaded-media
UPLOADED_RECORDINGS_DIR=uploaded_recordings

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_FROM_DISPLAY_NAME=MeetIQ

# AI provider
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=your-chat-deployment
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your-embedding-deployment
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536

# Azure AI Search
AZURE_AI_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_AI_SEARCH_API_KEY=your-search-admin-key
AZURE_AI_SEARCH_INDEX=meeting-transcript-chunks
AZURE_AI_SEARCH_API_VERSION=2025-09-01

# Feature flags
ENABLE_MICROSOFT_ONBOARDING=false
ENABLE_AI_SUMMARIES=false
ENABLE_AI_CHAT=false
ENABLE_BOT_INTERNAL_APIS=true
